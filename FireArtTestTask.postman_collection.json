{
  "info": {
    "name": "FireArt Test Task API",
    "_postman_id": "fireart-test-task",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5035"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "productId",
      "value": ""
    },
    {
      "key": "resetToken",
      "value": ""
    }
  ],
