            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\"name\": \"Test Widget\", \"description\": \"A test product\", \"price\": 29.99, \"category\": \"Electronics\"}"
