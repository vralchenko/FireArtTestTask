        {
          "name": "Create Product - Success",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('Has product', () => {",
                  "  var json = pm.response.json();",
                  "  pm.expect(json.id).to.be.a('string');",
